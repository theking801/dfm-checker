# DFM Checker - Configuration
# Copie ce fichier en .env et ajuste les valeurs

# Port du serveur backend (défaut: 8000)
PORT=8000

# Origines CORS autorisées (séparées par des virgules)
# En développement : http://localhost:5173 (Vite)
# En production : ajoute l'URL de ton frontend déployé
CORS_ORIGINS=http://localhost:5173

# Taille maximale des fichiers en MB (défaut: 50)
MAX_FILE_SIZE_MB=50

# Niveau de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Clé API pour l'authentification admin (GÉNÉRER UNE CLÉ SÉCURISÉE EN PROD !)
# Exemple: openssl rand -base64 32
ADMIN_API_KEY=votre_cle_secrete_admin_tres_longue_et_aleatoire

# Optionnel: Supabase (pour analytics persistants)
# SUPABASE_URL=https://votre-projet.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key
