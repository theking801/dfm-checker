# URL de l'API backend (utilisée en production)
# En développement, le proxy Vite redirige /api vers localhost:8000
# Donc ce n'est nécessaire que pour le déploiement.
VITE_API_URL=http://localhost:8000

# Clé API admin (doit correspondre à ADMIN_API_KEY du backend)
# Utilisée pour protéger les endpoints /admin/*, /session/*, /activity/*
VITE_ADMIN_API_KEY=dev-admin-key-change-in-production

# Supabase (optionnel - pour analytics persistants + auth admin)
# VITE_SUPABASE_URL=https://votre-projet.supabase.co
# VITE_SUPABASE_ANON_KEY=votre_anon_key
